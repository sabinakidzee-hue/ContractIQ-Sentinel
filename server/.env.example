# ─── ContractIQ Sentinel — Server Environment Variables ──────────────────────
# Copy this file to server/.env and fill in your values.
# Never commit server/.env to source control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/contractiq?retryWrites=true&w=majority

# ── IBM watsonx.ai (Granite) ──────────────────────────────────────────────────
# Obtain from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_API_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# ── IBM watsonx Orchestrate (optional) ────────────────────────────────────────
# Only required if you deploy an Orchestrate agent to a Watson Assistant channel.
WATSONX_ORCHESTRATE_URL=
WATSONX_ORCHESTRATE_AGENT_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production
CLIENT_URL=http://localhost:3000

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true to bypass AI calls and use mock responses (useful for demos)
USE_MOCK_ANALYSIS=false
